<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="?android:attr/colorBackground">

        <!-- Input Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 机组配置 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="机组配置"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:fontFamily="@font/simhei" />

                    <Spinner
                        android:id="@+id/crewSpinner"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1.5"
                        android:background="@drawable/spinner_background" />
                </LinearLayout>

                <!-- 起飞时间 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="起飞时间"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:fontFamily="@font/simhei" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.5"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <NumberPicker
                            android:id="@+id/hourPicker"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="："
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginHorizontal="4dp"
                            android:fontFamily="@font/simhei" />

                        <NumberPicker
                            android:id="@+id/minutePicker"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 航段数 -->
                <LinearLayout
                    android:id="@+id/legLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="航段数"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:fontFamily="@font/simhei" />

                    <Spinner
                        android:id="@+id/legSpinner"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1.5"
                        android:background="@drawable/spinner_background" />
                </LinearLayout>

                <!-- 休息设施 -->
                <LinearLayout
                    android:id="@+id/restLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="休息设施"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:fontFamily="@font/simhei" />

                    <Spinner
                        android:id="@+id/restSpinner"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1.5"
                        android:background="@drawable/spinner_background" />
                </LinearLayout>

                <!-- 休息间隔 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="休息间隔"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:fontFamily="@font/simhei" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.5"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <NumberPicker
                            android:id="@+id/restHourPicker"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="："
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginHorizontal="4dp"
                            android:fontFamily="@font/simhei" />

                        <NumberPicker
                            android:id="@+id/restMinutePicker"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Calculate Button -->
        <Button
            android:id="@+id/calcButton"
            android:layout_width="200dp"
            android:layout_height="46dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:text="开始计算"
            android:textSize="16sp"
            android:fontFamily="@font/simhei" />

        <!-- Result Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/resultText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="请输入信息后点击「开始计算」"
                    android:textSize="18sp"
                    android:lineSpacingMultiplier="1.4"
                    android:fontFamily="@font/simhei"
                    android:textColor="?android:attr/textColorPrimary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
