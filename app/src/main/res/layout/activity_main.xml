<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 飞行信息卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 机组配置 -->
                <!-- 机组配置下拉框：Exposed Dropdown Menu 样式，点击展开所有选项 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/crewInput"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="机组配置"
                    android:layout_marginBottom="12dp"
                    app:endIconMode="dropdown_menu">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/crewDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:saveEnabled="false" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 起飞时间：NumberPicker -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <NumberPicker
                        android:id="@+id/hourPicker"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="："
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginHorizontal="8dp"
                        android:textColor="?attr/colorOnSurface" />

                    <NumberPicker
                        android:id="@+id/minutePicker"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1" />
                </LinearLayout>

                <!-- 航段数 -->
                <LinearLayout
                    android:id="@+id/legLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/legInput"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="航段数">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/legDropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:saveEnabled="false" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- 休息设施 -->
                <LinearLayout
                    android:id="@+id/restLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/restInput"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="休息设施">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/restDropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:saveEnabled="false" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- 休息间隔：NumberPicker -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <NumberPicker
                        android:id="@+id/restHourPicker"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="："
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginHorizontal="8dp"
                        android:textColor="?attr/colorOnSurface" />

                    <NumberPicker
                        android:id="@+id/restMinutePicker"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 计算按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/calcButton"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:text="开始计算"
            android:textSize="16sp"
            app:cornerRadius="28dp" />

        <!-- 计算结果卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/resultText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="请输入信息后点击「开始计算」"
                    android:textSize="16sp"
                    android:lineSpacingMultiplier="1.4"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
